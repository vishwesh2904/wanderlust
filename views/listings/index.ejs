<% layout("/layouts/boilerplate")%>

    <style>
        body {
            background-color: #f8f9fa;
            font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
        }

        .filters-container {
            background: white;
            border-radius: 10px;
            padding: 8px;
            margin: 10px 0;
            box-shadow: 0 2px 12px rgba(0,0,0,0.08);
            border: 1px solid #e9ecef;
        }

        .filters-wrapper {
            display: flex;
            align-items: center;
            justify-content: space-between;
            gap: 20px;
            flex-wrap: wrap;
        }

        #filters {
            display: flex;
            flex-wrap: wrap;
            gap: 10px;
            flex: 1;
            min-width: 0;
        }

        .filter {
            border: 1.5px solid #dee2e6;
            border-radius: 12px;
            padding: 10px 12px;
            text-decoration: none;
            color: #495057;
            background: white;
            transition: all 0.3s ease;
            font-size: 0.9rem;
            font-weight: 500;
            white-space: nowrap;
            display: flex;
            align-items: center;
            gap: 8px;
        }

        .filter:hover {
            border-color: #007bff;
            background: #f8f9ff;
            color: #007bff;
            transform: translateY(-1px);
            box-shadow: 0 4px 12px rgba(0,123,255,0.15);
        }

        /* .filter.active {
            background: #007bff;
            border-color: #007bff;
            color: white;
        } */

        .filter i {
            font-size: 1rem;
        }

        .tax-toggle {
            border: 1.5px solid #dee2e6;
            border-radius: 12px;
            padding: 12px 20px;
            background: white;
            min-width: 220px;
            flex-shrink: 0;
            transition: all 0.3s ease;
        }

        .tax-toggle:hover {
            border-color: #007bff;
            background: #f8f9ff;
        }

        .form-check-input:checked {
            background-color: #007bff;
            border-color: #007bff;
        }

        .form-check-label {
            font-weight: 500;
            color: #495057;
            cursor: pointer;
        }

        .listings-grid {
            display: grid;
            grid-template-columns: repeat(auto-fill, minmax(300px, 1fr));
            gap: 24px;
            margin-top: 30px;
        }

        .listing-card {
            background: white;
            border-radius: 16px;
            overflow: hidden;
            box-shadow: 0 2px 12px rgba(0,0,0,0.08);
            transition: all 0.3s ease;
            border: 1px solid #e9ecef;
            text-decoration: none;
            color: inherit;
        }

        .listing-card:hover {
            transform: translateY(-4px);
            box-shadow: 0 8px 25px rgba(0,0,0,0.15);
            text-decoration: none;
            color: inherit;
        }

        .card-img-top {
            height: 240px;
            object-fit: cover;
            width: 100%;
        }

        .card-body {
            padding: 20px;
        }

        .card-text {
            margin: 0;
            font-size: 1rem;
        }

        .listing-title {
            font-weight: 600;
            color: #212529;
            margin-bottom: 8px;
            display: -webkit-box;
            -webkit-line-clamp: 2;
            -webkit-box-orient: vertical;
            overflow: hidden;
        }

        .listing-price {
            font-size: 1.1rem;
            font-weight: 600;
            color: #007bff;
        }

        .tax-info {
            display: none;
            color: #6c757d;
            font-size: 0.9rem;
            font-weight: 400;
        }

        .container-fluid {
            max-width: 1400px;
            margin: 0 auto;
            padding: 0 20px;
        }

        /* Responsive adjustments */
        @media (max-width: 768px) {
            .filters-wrapper {
                flex-direction: column;
                align-items: stretch;
            }
            
            .tax-toggle {
                min-width: auto;
                width: 100%;
            }
            
            .listings-grid {
                grid-template-columns: 1fr;
            }
            
            #filters {
                justify-content: center;
            }
        }

        @media (max-width: 576px) {
            .filters-container {
                margin: 10px 0;
                padding: 15px;
            }
            
            .filter {
                font-size: 0.8rem;
                padding: 8px 12px;
            }
        }
    </style>
</head>
<body>
    <div class="container-fluid">
        <div class="filters-container">
            <div class="filters-wrapper">
                <div id="filters">
                    <a href="/listings/category/Trending" class="filter active">
                        <i class="fa-solid fa-fire"></i> Trending
                    </a>
                    <a href="/listings/category/Rooms" class="filter">
                        <i class="fa-solid fa-bed"></i> Rooms
                    </a>
                    <a href="/listings/category/Iconic cities" class="filter">
                        <i class="fa-solid fa-mountain-city"></i> Iconic cities
                    </a>
                    <a href="/listings/category/Mountains" class="filter">
                        <i class="fa-solid fa-mountain"></i> Mountains
                    </a>
                    <a href="/listings/category/Castles" class="filter">
                        <i class="fa-brands fa-fort-awesome"></i> Castles
                    </a>
                    <a href="/listings/category/Pools" class="filter">
                        <i class="fa-solid fa-person-swimming"></i> Pools
                    </a>
                    <a href="/listings/category/Villas" class="filter">
                        <i class="fa-solid fa-house"></i> Villas
                    </a>
                    <a href="/listings/category/Beach" class="filter">
                        <i class="fa-solid fa-umbrella-beach"></i> Beach
                    </a>
                    <a href="/listings/category/Camping" class="filter">
                        <i class="fa-solid fa-campground"></i> Camping
                    </a>
                    <a href="/listings/category/Farms" class="filter">
                        <i class="fa-solid fa-cow"></i> Farms
                    </a>
                    <a href="/listings/category/Arctic" class="filter">
                        <i class="fa-regular fa-snowflake"></i> Arctic
                    </a>
                    <a href="/listings/category/Domes" class="filter">
                        <i class="fa-solid fa-igloo"></i> Domes
                    </a>
                    <a href="/listings/category/Boats" class="filter">
                        <i class="fa-solid fa-sailboat"></i> Boats
                    </a>
                    <a href="/listings/category/Others" class="filter">
                        <i class="fa-solid fa-ellipsis"></i> Others
                    </a>
                </div>
                
                <div class="tax-toggle">
                    <div class="form-check form-switch">
                        <input
                            class="form-check-input"
                            type="checkbox"
                            role="switch"
                            id="flexSwitchCheckDefault"
                        />
                        <label class="form-check-label" for="flexSwitchCheckDefault">
                            Display prices post taxes
                        </label>
                    </div>
                </div>
            </div>
        </div>

         <div class="row row-cols-lg-3 row-cols-md-2 row-cols-sm-1 mt-3">
    <% for(let listing of allListings) { %>
    <a href="/listings/<%= listing._id%>" class="listing-link col">
      <div class="card listing-card">
        <img
          src="<%=listing.image.url%>"
          class="card-img-top"
          alt="listing_image"
          style="height: 20rem;"
        />
        <div class="card-img-overlay"></div>
        <div class="card-body">
          <p class="card-text">
            <b><%= listing.title %></b><br />
            &#8377;<%= listing.price.toLocaleString("en-IN") %>/night
            <i class="tax-info"> &nbsp;+18% GST</i>
          </p>
        </div>
      </div>
    </a>
    <% } %>
  </div>
</div>

    

        
    <script src="https://cdnjs.cloudflare.com/ajax/libs/bootstrap/5.3.0/js/bootstrap.bundle.min.js"></script>
    <script>
        // Tax toggle functionality
        let taxSwitch = document.getElementById("flexSwitchCheckDefault");
        taxSwitch.addEventListener("change", () => {
            let taxInfo = document.getElementsByClassName("tax-info");
            for (let info of taxInfo) {
                if (info.style.display !== "inline") {
                    info.style.display = "inline";
                } else {
                    info.style.display = "none";
                }
            }
        });

       
    </script>
</body>
</html>